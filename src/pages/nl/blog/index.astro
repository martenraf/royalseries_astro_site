---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = '/nl'; 

const allPosts = await getCollection('blog');
const posts = allPosts.filter(p => p.data.lang === "nl");
---
<BaseLayout title="Blog | The Royal Series" description="Insights on Union with Christ, Discipleship, and Living the Royal Life" lang="nl">
  <section class="py-24 md:py-28 px-4 sm:px-6 lg:px-8 bg-background">
    <div class="max-w-5xl mx-auto">
      <p class="text-accent font-display font-semibold text-sm uppercase tracking-wide">Blog</p>
      <h1 class="text-primary mt-2 text-4xl md:text-5xl">Blog</h1>
      <p class="mt-4 text-foreground/80 text-lg max-w-3xl">
        Insights on Union with Christ, Discipleship, and Living the Royal Life<br/>
        Discover practical wisdom and deep teaching about what it means to live from the River of God rather than striving in your own strength.
      </p>
      <div class="w-24 h-1 bg-accent rounded-full mt-6"></div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12">
        {posts.map(post => (
          <a href={`/nl/blog/${post.slug}/`} class="block bg-card border border-border rounded-xl p-7 hover:shadow-soft transition-shadow">
            <p class="text-sm text-foreground/60">
  {post.data.pubDate.toLocaleDateString('nl-NL', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  })}
</p>
            <h3 class="mt-2 text-2xl text-primary">{post.data.title}</h3>
            <p class="mt-3 text-foreground/80">{post.data.description}</p>
            <p class="mt-4 text-sm text-accent font-semibold">Read →</p>
          </a>
        ))}
      </div>

      <div class="mt-10 text-sm text-foreground/60">
        <p>Space reserved for future posts (add more .md files in <code>src/content/blog</code>).</p>
      </div>
    </div>
  </section>
</BaseLayout>
